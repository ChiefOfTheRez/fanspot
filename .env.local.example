# Local-only test mode. Use this if you switch back to SQLite.
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-secret-before-deployment"
APP_ENV="development"
NODE_ENV="development"
EMAIL_PROVIDER="console"
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AWS_REGION="us-east-2"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""
UPLOADS_ENABLED="false"

# OAuth sign-ins
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_APPLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Test deployments can auto-verify email while EMAIL_PROVIDER=console
FANSPOT_TEST_MODE=true
