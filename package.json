{
  "name": "fanspot-aws-test-deploy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "check": "npm run db:generate && npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "analyze": "prisma generate && next build",
    "check:env": "tsx scripts/check-env.ts",
    "check:release": "tsx scripts/check-release.ts",
    "seed:admin": "tsx prisma/seed.ts",
    "audit:mock": "tsx scripts/mock-audit.ts",
    "smoke": "npm run typecheck && npm run test && npm run test:e2e",
    "final:verify": "npm run check:env && npm run db:generate && npm run typecheck && npm run test && npm run build",
    "postinstall": "prisma generate",
    "create:admin": "tsx scripts/create-admin.ts",
    "aws:db:push": "prisma generate && prisma db push",
    "aws:deploy-check": "npm run check:env && npm run typecheck && npm run test && npm run build",
    "use:local-sqlite": "node scripts/use-prisma-schema.cjs local",
    "use:aws-postgres": "node scripts/use-prisma-schema.cjs aws",
    "start:ecs": "prisma generate && prisma db push && prisma db seed && next start",
    "ecs:db:push": "prisma generate && prisma db push",
    "ecs:build-image": "docker build -t fanspot-test ."
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@prisma/client": "^6.13.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.4.6",
    "next-auth": "^4.24.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76",
    "date-fns": "^4.1.0",
    "nanoid": "^5.1.5",
    "@aws-sdk/client-sesv2": "^3.864.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.4.6",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "prisma": "^6.13.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4",
    "@eslint/eslintrc": "^3.3.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
