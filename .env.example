# FanSpot AWS ECS test-server environment variables.
# Put these in ECS service environment variables or AWS Secrets Manager.
# Do NOT commit a real .env file with live secrets.

# RDS PostgreSQL connection string.
DATABASE_URL="postgresql://fanspot_admin:CHANGE_ME@your-rds-endpoint.us-east-2.rds.amazonaws.com:5432/fanspot?schema=public"

# Use the temporary ECS/ALB URL first. Replace with your custom domain later.
NEXTAUTH_URL="http://your-ecs-load-balancer-url"
APP_URL="http://your-ecs-load-balancer-url"
NEXTAUTH_SECRET="generate-a-long-random-secret"
APP_ENV="production"
NODE_ENV="production"

# Google sign-in stays disabled until OAuth credentials are created.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Keep email in console mode for the first live test. Switch to ses later.
EMAIL_PROVIDER="console"
AWS_REGION="us-east-2"
AWS_SES_FROM_EMAIL=""
AWS_SES_CONFIGURATION_SET=""

# Keep uploads disabled until S3/CloudFront permissions are ready.
UPLOADS_ENABLED="false"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""

# Leave blank until Segpay webhook signing is configured.
SEGPAY_WEBHOOK_SECRET=""

# OAuth sign-ins
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_APPLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Test deployments can auto-verify email while EMAIL_PROVIDER=console
FANSPOT_TEST_MODE=true
