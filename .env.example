# AWS production/testing database. Use the RDS PostgreSQL connection string here.
DATABASE_URL="postgresql://fanspot_admin:CHANGE_ME@your-rds-endpoint.amazonaws.com:5432/fanspot?schema=public"

# Set this to your live domain after the custom domain is connected.
NEXTAUTH_URL="https://yourdomain.com"
APP_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-a-long-random-secret"
APP_ENV="production"
NODE_ENV="production"

# Google sign-in. Enable only after Google OAuth credentials are created.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Amazon SES email verification.
EMAIL_PROVIDER="ses"
AWS_REGION="us-east-1"
AWS_SES_FROM_EMAIL="FanSpot <no-reply@yourdomain.com>"
AWS_SES_CONFIGURATION_SET=""

# S3/CloudFront uploads. Keep UPLOADS_ENABLED=false until the bucket and permissions are ready.
UPLOADS_ENABLED="false"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""
