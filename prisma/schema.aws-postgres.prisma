// AWS RDS PostgreSQL reference schema. Copy this over schema.prisma before production migration planning.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FAN
  CREATOR
  MODERATOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  LIMITED
  SUSPENDED
  DELETED
}

enum CreatorApplicationStatus {
  DRAFT
  SUBMITTED
  NEEDS_MORE_INFO
  APPROVED
  REJECTED
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  FLAGGED
  REMOVED
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  SUPPORTERS
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  HARASSMENT
  IMPERSONATION
  UNSAFE_CONTENT
  PAYMENT_ISSUE
  COPYRIGHT
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum PaymentEventType {
  CHECKOUT_STARTED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_CREATED
  CHARGEBACK_OPENED
  CHARGEBACK_WON
  CHARGEBACK_LOST
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  PAYOUT
  REFUND
  CHARGEBACK
  ADJUSTMENT
}

enum PayoutStatus {
  DRAFT
  REVIEWING
  APPROVED
  PAID
  FAILED
  CANCELLED
}

enum NotificationType {
  FOLLOW
  COMMENT
  LIKE
  MESSAGE
  REPORT_UPDATE
  SYSTEM
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  username           String             @unique
  displayName        String
  passwordHash       String?
  role               UserRole           @default(FAN)
  status             AccountStatus      @default(ACTIVE)
  avatarUrl          String?
  bannerUrl          String?
  bio                String?
  location           String?
  websiteUrl         String?
  emailVerified      DateTime?
  emailMarketingOptIn Boolean            @default(false)
  phoneNumber        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  accounts           Account[]
  sessions           Session[]
  creatorProfile     CreatorProfile?
  creatorApplication CreatorApplication?
  posts              Post[]
  comments           Comment[]
  likes              Like[]
  bookmarks          Bookmark[]
  sentMessages       Message[]          @relation("MessageSender")
  receivedMessages   Message[]          @relation("MessageReceiver")
  following          Follow[]           @relation("FanFollows")
  followers          Follow[]           @relation("CreatorFollowers")
  subscriptions      Subscription[]     @relation("FanSubscriptions")
  subscribers        Subscription[]     @relation("CreatorSubscriptions")
  submittedReports   Report[]           @relation("ReportSubmitter")
  auditLogs          AuditLog[]         @relation("AuditActor")
  notifications      Notification[]
  mediaAssets        MediaAsset[]       @relation("MediaOwner")
  supportTickets     SupportTicket[]
  creatorLedger      LedgerEntry[]      @relation("CreatorLedger")
  blocksMade         Block[]            @relation("Blocker")
  blockedBy          Block[]            @relation("Blocked")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CreatorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline            String
  category            String
  intro               String  
  monthlyPriceCents   Int      @default(999)
  isVerified          Boolean  @default(false)
  isFoundingCreator   Boolean  @default(false)
  isAcceptingFans     Boolean  @default(true)
  featuredRank        Int?
  profileCompletion   Int      @default(30)
  themePreset         String   @default("midnight")
  backgroundUrl       String?
  backgroundBlur      Int      @default(18)
  avatarMode          String   @default("STATIC")
  bannerMode          String   @default("STATIC")
  badgeText           String?
  profileAccentColor  String   @default("#1e6bff")
  pinnedPostId        String?
  highlightedTierId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tiers               CreatorTier[]
}

model CreatorTier {
  id            String   @id @default(cuid())
  creatorId     String
  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name          String
  description   String
  priceCents    Int
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
}

model CreatorApplication {
  id              String                   @id @default(cuid())
  userId          String                   @unique
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          CreatorApplicationStatus @default(DRAFT)
  displayName     String
  desiredUsername String?
  category        String
  audienceSummary String                  
  planSummary     String                  
  reviewedById    String?
  reviewNotes     String?                 
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model Post {
  id               String         @id @default(cuid())
  authorId         String
  author           User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title            String?
  body             String        
  visibility       PostVisibility @default(PUBLIC)
  status           PostStatus     @default(PENDING_REVIEW)
  scheduledFor     DateTime?
  publishedAt      DateTime?
  isPinned         Boolean        @default(false)
  requiredTierId   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  media            MediaAsset[]
  comments         Comment[]
  likes            Like[]
  bookmarks        Bookmark[]
  reports          Report[]

  @@index([authorId, createdAt])
  @@index([status, createdAt])
}

model MediaAsset {
  id              String    @id @default(cuid())
  ownerId         String
  owner           User      @relation("MediaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  kind            MediaKind
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  durationSeconds Int?
  s3Key           String
  cdnUrl          String?
  altText         String?
  status          PostStatus @default(PENDING_REVIEW)
  createdAt       DateTime   @default(now())

  @@index([ownerId, createdAt])
}

model Follow {
  id        String   @id @default(cuid())
  fanId     String
  creatorId String
  fan       User     @relation("FanFollows", fields: [fanId], references: [id], onDelete: Cascade)
  creator   User     @relation("CreatorFollowers", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([fanId, creatorId])
}

model Subscription {
  id             String             @id @default(cuid())
  fanId          String
  creatorId      String
  tierId         String?
  fan            User               @relation("FanSubscriptions", fields: [fanId], references: [id], onDelete: Cascade)
  creator        User               @relation("CreatorSubscriptions", fields: [creatorId], references: [id], onDelete: Cascade)
  tier           CreatorTier?        @relation(fields: [tierId], references: [id], onDelete: SetNull)
  status         SubscriptionStatus @default(ACTIVE)
  priceCents     Int
  processor      String?
  processorRef   String?
  startedAt      DateTime           @default(now())
  renewsAt       DateTime?
  cancelledAt    DateTime?

  paymentEvents  PaymentEvent[]

  @@unique([fanId, creatorId])
  @@index([creatorId, status])
}

model PaymentEvent {
  id             String           @id @default(cuid())
  subscriptionId String?
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  type           PaymentEventType
  processor      String
  processorRef   String?
  amountCents    Int?
  currency       String           @default("USD")
  rawPayload      Json?
  createdAt      DateTime         @default(now())

  @@index([processor, processorRef])
}

model LedgerEntry {
  id             String          @id @default(cuid())
  creatorId      String
  creator        User            @relation("CreatorLedger", fields: [creatorId], references: [id], onDelete: Cascade)
  type           LedgerEntryType
  amountCents    Int
  currency       String          @default("USD")
  description    String
  sourceRef      String?
  availableAt    DateTime?
  createdAt      DateTime        @default(now())

  payoutItem     PayoutItem?

  @@index([creatorId, createdAt])
}

model PayoutBatch {
  id             String       @id @default(cuid())
  status         PayoutStatus @default(DRAFT)
  title          String
  notes          String?     
  createdAt      DateTime     @default(now())
  reviewedAt     DateTime?
  paidAt         DateTime?

  items          PayoutItem[]
}

model PayoutItem {
  id             String       @id @default(cuid())
  batchId        String
  ledgerEntryId  String       @unique
  creatorId      String
  amountCents    Int
  status         PayoutStatus @default(DRAFT)
  payoutMethod   String?
  externalRef    String?
  notes          String?     

  batch          PayoutBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ledgerEntry    LedgerEntry  @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  body        String  
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([senderId, receiverId, createdAt])
}

model Report {
  id          String       @id @default(cuid())
  submitterId String
  postId      String?
  reason      ReportReason
  details     String?     
  status      ReportStatus @default(OPEN)
  assignedTo  String?
  resolution  String?     
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  submitter   User         @relation("ReportSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  body      String  
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

model CreatorInvite {
  id          String   @id @default(cuid())
  email       String
  code        String   @unique
  status      String   @default("OPEN")
  notes       String? 
  invitedById String?
  claimedById String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email, status])
}

model MediaReview {
  id          String   @id @default(cuid())
  mediaAssetId String
  status      String   @default("PENDING")
  riskScore   Int      @default(0)
  reason      String?
  reviewerId  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
}

model WebhookEvent {
  id            String   @id @default(cuid())
  processor     String
  processorRef  String
  eventType     String
  payload        Json
  processedAt    DateTime?
  createdAt      DateTime @default(now())

  @@unique([processor, processorRef])
  @@index([processor, eventType])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OperationalStatus {
  GREEN
  YELLOW
  RED
}

model SystemHealthCheck {
  id          String            @id @default(cuid())
  key         String            @unique
  status      OperationalStatus @default(GREEN)
  message     String?
  checkedAt   DateTime          @default(now())
  metadata    Json?

  @@index([status, checkedAt])
}

model ChargebackCase {
  id             String   @id @default(cuid())
  processor      String
  processorRef   String   @unique
  userId         String?
  creatorId      String?
  amountCents    Int
  currency       String   @default("USD")
  status         String   @default("OPEN")
  evidenceDueAt  DateTime?
  notes          String? 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, evidenceDueAt])
  @@index([creatorId, createdAt])
}

model AdminDecision {
  id          String   @id @default(cuid())
  actorId     String?
  targetType  String
  targetId    String
  decision    String
  notes       String  
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

model ContentLabel {
  id          String   @id @default(cuid())
  targetType  String
  targetId    String
  label       String
  confidence  Int      @default(0)
  source      String   @default("SYSTEM")
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([label, createdAt])
}

model CreatorMilestone {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String?
  achievedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([creatorId, achievedAt])
}

model PlatformAnnouncement {
  id          String   @id @default(cuid())
  title       String
  body        String  
  audience    String   @default("ALL")
  status      String   @default("DRAFT")
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, scheduledAt])
}

model RiskSignal {
  id          String   @id @default(cuid())
  targetType  String
  targetId    String
  score       Int
  reason      String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([score, createdAt])
}
